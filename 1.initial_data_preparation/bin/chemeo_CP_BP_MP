import asyncio
import httpx
import pandas as pd
from bs4 import BeautifulSoup
import urllib.parse
import re
import time
import random

# --- 설정 ---
CONCURRENCY_LIMIT = 5  
INPUT_FILE = 'PubChem_compound_CID.csv' 
OUTPUT_FILE = 'PubChem_Cp_Tboil_Tfus_data.csv' 

async def fetch_chemeo_data(client, smiles, index, total):
    if pd.isna(smiles) or str(smiles).lower() == 'nan':
        return index, None, None, None, None, None

    encoded_smiles = urllib.parse.quote(str(smiles).strip())
    search_url = f"https://www.chemeo.com/search?q={encoded_smiles}"
    
    cp_val, cp_phase, cp_temp, t_boil, t_fus = None, None, None, None, None
    
    try:
        resp = await client.get(search_url, follow_redirects=True, timeout=15.0)
        soup = BeautifulSoup(resp.text, 'html.parser')
        
        detail_link = soup.find('a', href=re.compile(r'^/cid/'))
        if detail_link:
            target_url = "https://www.chemeo.com" + detail_link['href']
            resp = await client.get(target_url, follow_redirects=True, timeout=15.0)
            soup = BeautifulSoup(resp.text, 'html.parser')

        rows = soup.find_all('tr')
        for tr in rows:
            cols = tr.find_all(['th', 'td']) 
            if len(cols) >= 2:
                label_text = cols[0].get_text(strip=True).lower()
                val_str = cols[1].get_text(strip=True)
                
                # --- 1. Tboil 추출 ---
                if label_text in ['tb', 'tboil'] or 'boiling point' in label_text:
                    if not t_boil: 
                        match = re.search(r'[-+]?\d*\.?\d+', val_str.split('±')[0])
                        if match: t_boil = match.group()

                # --- 2. Tfus 추출 ---
                elif label_text in ['tf', 'tfus'] or 'melting point' in label_text or 'fusion' in label_text:
                    if not t_fus:
                        match = re.search(r'[-+]?\d*\.?\d+', val_str.split('±')[0])
                        if match: t_fus = match.group()

                # --- 3. 297~299K 사이의 Cp, Phase, 온도 추출 ---
                elif 'cp' in label_text or 'heat capacity' in label_text:
                    if not cp_val: 
                        temp_str = ""
                        if len(cols) >= 4: 
                            temp_str = cols[3].get_text(strip=True)
                        
                        t_matches = re.findall(r'[-+]?\d*\.?\d+', temp_str)
                        if t_matches:
                            t_first = float(t_matches[0]) 
                            
                            if 297.0 <= t_first <= 299.0:
                                v_matches = re.findall(r'[-+]?\d*\.?\d+', val_str)
                                if v_matches:
                                    cp_val = v_matches[0]
                                    cp_temp = str(t_first)
                                    
                                    if 'gas' in label_text or 'cpg' in label_text:
                                        cp_phase = 'Gas'
                                    elif 'liq' in label_text or 'cpl' in label_text:
                                        cp_phase = 'Liquid'
                                    elif 'solid' in label_text or 'cps' in label_text:
                                        cp_phase = 'Solid'
                                    else:
                                        cp_phase = 'Unknown'
        
        print(f"[{index+1}/{total}] 완료: {smiles} (Cp: {cp_val}[{cp_phase}], Tb: {t_boil}, Tf: {t_fus})")
        return index, cp_val, cp_phase, cp_temp, t_boil, t_fus

    except Exception as e:
        print(f"[{index+1}/{total}] 실패 ({smiles}): {str(e)[:30]}")
        return index, None, None, None, None, None

async def main():
    print("CSV 파일을 로드하는 중입니다. (파일 크기에 따라 몇 초 정도 걸릴 수 있습니다...)")
    
    # 💡 인코딩 오류 우회를 위한 다중 시도 로직
    try:
        # 1차 시도: 기본 UTF-8
        df = pd.read_csv(INPUT_FILE, low_memory=False, encoding='utf-8')
    except UnicodeDecodeError:
        try:
            # 2차 시도: 한국어 윈도우 엑셀에서 저장한 경우 (CP949)
            df = pd.read_csv(INPUT_FILE, low_memory=False, encoding='cp949')
        except UnicodeDecodeError:
            try:
                # 3차 시도: 서유럽 표준 (PubChem 원본에서 주로 깨지는 문자 해결)
                df = pd.read_csv(INPUT_FILE, low_memory=False, encoding='latin1')
            except Exception as e:
                print(f"파일 로드 최종 실패: {e}")
                return
    except Exception as e:
        print(f"알 수 없는 파일 로드 오류: {e}")
        return

    # 소문자 smiles 우선 검색, PubChem 원본인 경우 isosmiles 컬럼 대응
    smiles_col = None
    if 'smiles' in df.columns:
        smiles_col = 'smiles'
    elif 'SMILES' in df.columns:
        smiles_col = 'SMILES'
    elif 'isosmiles' in df.columns:
        smiles_col = 'isosmiles'
        
    if not smiles_col:
        print(f"\n❌ CSV 파일에 'smiles' 관련 열이 없습니다.\n현재 열 목록: {df.columns.tolist()}")
        return

    smiles_list = df[smiles_col].tolist()
    total = len(smiles_list)
    semaphore = asyncio.Semaphore(CONCURRENCY_LIMIT)
    
    limits = httpx.Limits(max_keepalive_connections=5, max_connections=10)
    async with httpx.AsyncClient(limits=limits, verify=False) as client:
        tasks = []
        async def sem_task(smiles, i):
            async with semaphore:
                await asyncio.sleep(random.uniform(0.3, 0.8)) 
                return await fetch_chemeo_data(client, smiles, i, total)

        for i, smiles in enumerate(smiles_list):
            tasks.append(sem_task(smiles, i))
        
        results = await asyncio.gather(*tasks)

    # 결과 병합 및 새로운 컬럼명 지정
    results.sort(key=lambda x: x[0])
    df['Cp_Value'] = [r[1] for r in results]
    df['Cp_Phase'] = [r[2] for r in results]
    df['Cp_Temperature_K'] = [r[3] for r in results]
    df['Tboil_K'] = [r[4] for r in results]
    df['Tfus_K'] = [r[5] for r in results]
    
    # CSV로 최종 저장 (index 제외)
    df.to_csv(OUTPUT_FILE, index=False, encoding='utf-8-sig')
    print(f"\n✅ 조건 추출 완료! 파일 저장: {OUTPUT_FILE}")

if __name__ == "__main__":
    start_time = time.time()
    asyncio.run(main())
    print(f"전체 소요 시간: {time.time() - start_time:.2f}초")
